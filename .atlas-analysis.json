  "keyFeatures": [
    "CLI tool with compile and watch modes",
    "Transforms standard CSS to Roblox StyleSheet instances",
    "Supports CSS variables as StyleSheet tokens",
    "Maps CSS selectors to Roblox class/tag/name selectors",
    "Auto-generates pseudo-instance rules (UICorner, UIStroke, UIPadding, etc.)",
    "Flexbox and grid layout support via UIListLayout/UIGridLayout",
    "Theme support with data-theme and prefers-color-scheme",
    "Multiple output formats: Luau modules and RBXMX model files",
    "CSS nesting support",
    "Comprehensive property mapping with warnings for unsupported features"
  ],
  "publicApiSurface": [
    "compile(files, options)",
    "generateLuau(ir, options)",
    "generateRBXMX(ir)",
    "generateManifest(ir)",
    "rbx-css compile <files...>",
    "rbx-css watch <path>",
    "StyleSheetIR",
    "StyleRuleIR",
    "RobloxValue",
    "TokenValue",
    "PseudoInstanceIR",
    "WarningCollector"
